# ── AI provider (optional) ───────────────────────────────────────
# Leave ALL unset to run in SANDBOX mode: high-quality demo content,
# zero config, full flow works. Set ONE key to enable real AI generation.
# Keys are read server-side only and never reach the browser.

# Google Gemini — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash      # or gemini-3.5-flash | gemini-2.5-pro

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Force one provider when several keys are present: gemini | openai | anthropic
# AI_PROVIDER=gemini

# ── WordPress (optional) ──────────────────────────────────────────
# For the demo, WordPress credentials are entered in Settings and stored in
# the browser (localStorage) per-user. These env vars are only used if you
# later wire a single fixed site server-side. Sandbox mode needs none of this.
# WP_URL=https://your-site.com
# WP_USERNAME=admin
# WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
